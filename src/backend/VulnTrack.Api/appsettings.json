{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "__TENANT_ID__",
    "ClientId": "__CLIENT_ID__",
    "Audience": "api://__CLIENT_ID__",
    "Scopes": "access_as_user"
  },
  "MicrosoftGraph": {
    "BaseUrl": "https://graph.microsoft.com/v1.0",
    "Scopes": "user.read"
  },
  "Graph": {
    "SenderEmail": "__NOTIFICATION_SENDER_EMAIL__"
  },
  "ConnectionStrings": {
    "DefaultConnection": "__SQL_CONNECTION_STRING__"
  },
  "AzureStorage": {
    "AccountName": "__STORAGE_ACCOUNT_NAME__",
    "AttachmentsContainer": "attachments"
  },
  "ServiceBus": {
    "Namespace": "__SERVICE_BUS_NAMESPACE__",
    "VulnerabilityEventsQueue": "vulnerability-events",
    "NotificationsQueue": "notifications"
  },
  "ApplicationInsights": {
    "ConnectionString": "__APP_INSIGHTS_CONNECTION_STRING__"
  },
  "AllowedOrigins": [
    "https://vulntrack.example.com"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
